{{- $investigations := where .Site.RegularPages "Type" "investigations" -}}
[
{{- range $index, $page := $investigations -}}
{
  "url": {{ $page.RelPermalink | jsonify }},
  "title": {{ $page.Title | jsonify }},
  "content": {{ $page.Plain | jsonify }},
  "status": {{ $page.Params.status | jsonify }},
  "areas": {{ delimit (default (slice) $page.Params.areas) ", " | jsonify }},
  "topics": {{ delimit (default (slice) $page.Params.topics) ", " | jsonify }},
  "questions": {{ delimit (default (slice) $page.Params.questions) ", " | jsonify }},
  "tags": {{ delimit (default (slice) $page.Params.tags) ", " | jsonify }},
  "created": {{ $page.Params.created | jsonify }},
  "updated": {{ $page.Params.created | jsonify }}
}{{ if ne (add $index 1) (len $investigations) }},{{ end }}
{{- end }}
]
